{
  "expo": {
    "name": "Lighthouse",
    "slug": "lighthouse",
    "scheme": "lighthouse",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/aisles-of-man-app-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jeremyintal.lighthouse",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Lighthouse uses the microphone only to detect a gentle exhale for the balloon breathing exercise."
      }
    },
    "android": {
      "package": "com.jeremyintal.lighthouse",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Lighthouse uses the microphone only to detect a gentle exhale for the balloon breathing exercise."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
